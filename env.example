# ============================================================
# ReconAI - Configurazione
# Rinomina questo file in .env e inserisci le tue key
# NON condividere mai questo file — aggiungilo a .gitignore
# ============================================================

# ------------------------------------------------------------
# PROVIDER AI — scegli il default
# Puoi comunque cambiare provider a runtime quando lanci lo scan
# Valori possibili: anthropic, gemini, groq, openai
# ------------------------------------------------------------
AI_PROVIDER=gemini

# ------------------------------------------------------------
# GOOGLE GEMINI (gemini-2.5-flash)
# https://aistudio.google.com → API Keys
# Costo: GRATUITO con limiti generosi
# ------------------------------------------------------------
GEMINI_API_KEY=metti-la-tua-key-qui

# ------------------------------------------------------------
# GROQ (llama-3.3-70b) — il più veloce
# https://console.groq.com → API Keys
# Costo: GRATUITO con limiti generosi
# ------------------------------------------------------------
GROQ_API_KEY=metti-la-tua-key-qui

# ------------------------------------------------------------
# ANTHROPIC (claude-sonnet)
# https://console.anthropic.com → API Keys
# Costo: a pagamento, crediti iniziali inclusi
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-metti-la-tua-key-qui

# ------------------------------------------------------------
# OPENAI (gpt-4o-mini)
# https://platform.openai.com → API Keys
# Costo: a pagamento, crediti iniziali inclusi
# ------------------------------------------------------------
OPENAI_API_KEY=sk-metti-la-tua-key-qui

# ------------------------------------------------------------
# SHODAN
# https://shodan.io → My Account → API Key
# Costo: GRATUITO (piano oss, limitato)
# Nota: il lookup per host richiede piano a pagamento
# ------------------------------------------------------------
SHODAN_API_KEY=metti-la-tua-key-qui

# ------------------------------------------------------------
# VIRUSTOTAL
# https://virustotal.com → profilo → API Key
# Costo: GRATUITO (500 req/giorno, 4 req/minuto)
# ------------------------------------------------------------
VIRUSTOTAL_API_KEY=metti-la-tua-key-qui

# ------------------------------------------------------------
# TELEGRAM
# 1. Cerca @BotFather su Telegram → /newbot → copia il token
# 2. Cerca @userinfobot → copia il tuo Chat ID
# 3. Apri una chat col tuo bot e invia /start
# Costo: GRATUITO
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=metti-il-tuo-token-qui
TELEGRAM_CHAT_ID=metti-il-tuo-chat-id-qui
